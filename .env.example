# 复制为 .env 并填写密钥
# cp .env.example .env

# ---------- LLM：商汤 SenseNova Token Plan ----------
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://token.sensenova.cn/v1
OPENAI_MODEL=deepseek-v4-flash

# ---------- Ollama Embedding ----------
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# ---------- OpenWeather（Agent get_weather 工具）----------
OPENWEATHER_API_KEY=your_api_key
OPENWEATHER_API_URL=https://api.openweathermap.org/data/2.5/weather

# Tavily 搜索引擎 API 密钥
TAVILY_API_KEY=your_api_key

# ---------- JWT / 认证安全 ----------
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRE_HOURS=2
JWT_REFRESH_EXPIRE_DAYS=7
REGISTRATION_ENABLED=false
# 前端是否显示注册入口（需与 REGISTRATION_ENABLED 保持一致）
VITE_REGISTRATION_ENABLED=false
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
LOGIN_RATE_LIMIT_PER_IP=20
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=16
PASSWORD_ALLOWED_SPECIAL=!@#$%^&*
PASSWORD_REQUIRE_UPPER=true
PASSWORD_REQUIRE_LOWER=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true
# 密码传输 AES 密钥（32 字节 Base64），前后端需保持一致
PASSWORD_ENCRYPT_KEY=change-me-generate-with-openssl-rand-base64-32
VITE_PASSWORD_ENCRYPT_KEY=change-me-generate-with-openssl-rand-base64-32

# 上传与审计
UPLOAD_MAX_SIZE_MB=20
SENSITIVE_WORDS=走私,贩毒,爆炸物,制毒,黑客攻击,钓鱼网站,色情
TOOL_QUOTA_WEB_SEARCH_DAILY=50
TOOL_QUOTA_WEATHER_DAILY=30
TOOL_QUOTA_LLM_DAILY=200

# ---------- Agent 治理 ----------
# 单轮对话内工具调用次数上限
AGENT_MAX_TOOL_ROUNDS=8
# Agent 流式回答总超时（秒）
AGENT_REPLY_TIMEOUT_SECONDS=600
# 连续失败多少次后触发熔断
AGENT_CIRCUIT_BREAKER_FAIL_THRESHOLD=5
# 熔断冷却时间（秒）
AGENT_CIRCUIT_BREAKER_COOLDOWN_SECONDS=120
# 单用户每日 Token 估算配额（0=不限；按字符数粗略折算）
USER_TOKEN_QUOTA_DAILY=0
USER_TOKEN_ESTIMATE_CHARS_PER_TOKEN=2.0
# Prompt 版本（app/prompts/unified_agent/{version}.txt）
AGENT_PROMPT_VERSION=v1
# 灰度版本与分流比例（0-100，按 user_id 哈希）
AGENT_PROMPT_CANARY_VERSION=
AGENT_PROMPT_CANARY_PERCENT=0
# 按场景路由模型（空则使用 OPENAI_MODEL）
OPENAI_MODEL_CHAT=
OPENAI_MODEL_RERANK=
OPENAI_MODEL_FALLBACK=

# ---------- 预置账号（首次启动写入数据库，勿提交真实密码）----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
USER_USERNAME=user
USER_PASSWORD=User@123

# ---------- 应用参数 ----------
QDRANT_COLLECTION=standards
KNOWLEDGE_BASE=default
TOP_K=4
SCORE_THRESHOLD=0.6
HISTORY_MAX_MESSAGES=20

# 混合检索（Qdrant dense+sparse 原生混合；false 时仅 dense）
RETRIEVAL_HYBRID_ENABLED=true
# QDRANT_HYBRID_COLLECTION_SUFFIX=_hybrid
RETRIEVAL_RRF_K=60
RETRIEVAL_CANDIDATE_TOP_K=12
# LLM 重排（额外一次 Chat 调用，典型 +3~8s，计入「思考用时」；非百毫秒 cross-encoder）
# 关闭可显著加速检索；需要更高精度时改为 true
RETRIEVAL_RERANK_ENABLED=false
# 送入 LLM 打分的候选条数（越大越慢）
RETRIEVAL_RERANK_CANDIDATES=8
TOP_K=4

# 分块：semantic=Ollama embedding 语义边界 + 超长 fixed 兜底；fixed=仅固定 token
# 单块目标 512–1024 token（下限内置，上限=CHUNK_TOKEN_SIZE）
CHUNK_STRATEGY=semantic
CHUNK_TOKEN_SIZE=1024
CHUNK_TOKEN_OVERLAP=154
CHUNK_SEMANTIC_SIMILARITY_THRESHOLD=0.60

# 基础设施连接：
#   本地 → .env.local
#   Docker → docker-compose environment 注入
